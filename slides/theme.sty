% blocks
\setbeamercolor{block title theorem}{fg=white, bg=unibo-red!80}
\setbeamercolor{block body theorem}{fg=black, bg=unibo-gray!10}

\newcounter{constructioncount}[section]
\renewcommand{\theconstructioncount}{\thesection.\arabic{constructioncount}}

\newcounter{theoremcount}[section]
\renewcommand{\thetheoremcount}{\thesection.\arabic{theoremcount}}

\setbeamercolor{block title construction}{fg=white, bg=unibo-red!80}
\setbeamercolor{block body construction}{fg=black, bg=unibo-gray!10}

\newenvironment{unibotheorem}[1][]{%
    \refstepcounter{theoremcount}% 
    \par\vskip\medskipamount%
    \begin{beamercolorbox}[wd=\textwidth, ht=2.5ex, dp=1ex, leftskip=0.5em]{block title theorem}
        \usebeamerfont*{block title theorem}\textbf{Theorem:} #1%
    \end{beamercolorbox}%
    {\nointerlineskip\vskip-0.5pt}%
    % Body Box (Slightly Gray)
    \usebeamerfont{block body theorem}%
    \begin{beamercolorbox}[wd=\textwidth, sep=0.5em, vmode]{block body theorem}%
        \setbeamercolor{itemize item}{fg=unibo-red}%
        \setbeamercolor{itemize subitem}{fg=unibo-red}%
        \itshape
}{%
    \end{beamercolorbox}\vskip\smallskipamount%
}

\newenvironment{construction}[1][]{
    \refstepcounter{constructioncount}
    \par\vskip\medskipamount%
    \begin{beamercolorbox}[wd=\textwidth, ht=2.5ex, dp=1ex, leftskip=0.5em]{block title construction}
    \usebeamerfont*{block title construction}\textbf{Construction:} #1%
    \end{beamercolorbox}%
    {\nointerlineskip\vskip-0.5pt}%
    \usebeamerfont{block body construction}%
    \begin{beamercolorbox}[wd=\textwidth, sep=0.5em, vmode]{block body construction}%
    \setbeamercolor{itemize item}{fg=unibo-red}%
    \setbeamercolor{itemize subitem}{fg=unibo-red}%
}{%
  \end{beamercolorbox}\vskip\smallskipamount%
}

